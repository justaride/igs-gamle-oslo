DB_PASSWORD=change-me
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
PORT=3001
API_BASE_URL=https://your-api-host.example.com
ELEVATION_CACHE_DIR=/tmp/igs-elevation-cache
SPECIES_CACHE_DIR=/tmp/igs-species-cache
OSM_REQUEST_TIMEOUT_S=120
KIM_EXCEL_PATH=/absolute/path/to/IGS-Mapping-Gamlebyen.xlsx
PIPELINE_AUTO_RUN=true
PIPELINE_KEEP_ALIVE=true
PIPELINE_ARGS=--skip-elevation --skip-species
